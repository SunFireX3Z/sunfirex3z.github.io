---
import { posts } from '@/data/posts';

const { to } = Astro.props;

// Temukan postingan terkait berdasarkan path yang diberikan.
const relatedPost = posts.find(p => p.path === to);

let showComponent = true;
if (!relatedPost) {
  console.error(`[RelatedArticle] Artikel dengan link "${to}" tidak ditemukan.`);
  showComponent = false;
}

const { metadata, path: linkToShow } = relatedPost || {};
---
{showComponent && (
  <div class="not-prose my-8">
    <a href={linkToShow} class="group flex items-start gap-4 rounded-lg border border-sky-200 bg-sky-50 p-4 transition-all duration-200 hover:border-sky-400 hover:bg-sky-100 hover:shadow-lg">
      <div class="flex-shrink-0 pt-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6 text-sky-500 transition-colors group-hover:text-sky-600"><path d="M12.232 4.232a2.5 2.5 0 0 1 3.536 3.536l-1.225 1.224a.75.75 0 0 0 1.061 1.06l1.224-1.224a4 4 0 0 0-5.656-5.656l-3 3a4 4 0 0 0 .225 5.865.75.75 0 0 0 .977-1.138 2.5 2.5 0 0 1-.142-3.665l3-3Z" /><path d="M8.603 14.397a2.5 2.5 0 0 1-3.536-3.536l1.225-1.224a.75.75 0 0 0-1.061-1.06l-1.224 1.224a4 4 0 0 0 5.656 5.656l3-3a4 4 0 0 0-.225-5.865.75.75 0 0 0-.977 1.138 2.5 2.5 0 0 1 .142 3.665l-3 3Z" /></svg>
      </div>
      <div class="flex-1">
        <p class="mb-1 text-sm font-bold uppercase tracking-wider text-sky-600">Baca Juga</p>
        <h4 class="not-prose mt-0 mb-1 border-none p-0 text-base font-bold text-sky-900 group-hover:text-sky-700">{metadata.title}</h4>
        <p class="prose prose-sm m-0 max-w-none text-sky-800 line-clamp-2 prose-code:before:content-none prose-code:after:content-none">{metadata.description}</p>
      </div>
      <div class="self-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6 text-sky-400 transition-transform duration-300 group-hover:translate-x-1 group-hover:text-sky-600"><path fill-rule="evenodd" d="M2 10a.75.75 0 0 1 .75-.75h12.59l-2.1-1.95a.75.75 0 1 1 1.02-1.1l3.5 3.25a.75.75 0 0 1 0 1.1l-3.5 3.25a.75.75 0 1 1-1.02-1.1l2.1-1.95H2.75A.75.75 0 0 1 2 10Z" clip-rule="evenodd" /></svg>
      </div>
    </a>
  </div>
)}