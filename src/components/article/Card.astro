---
const { path, title, description, author, publishDate, thumbnail, authorAvatar, isLarge = false } = Astro.props;
---
<a href={path} class="group flex h-full flex-col overflow-hidden rounded-xl bg-white shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg">
  <div class="relative flex-shrink-0 overflow-hidden">
    <img class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.02] aspect-video" src={thumbnail.src} alt={`Thumbnail for ${title}`} />
  </div>
  <div class="flex flex-1 flex-col justify-between p-6">
    <div class="flex-1">
        <h2 class="text-xl font-bold text-gray-900 group-hover:text-orange-600">
          {title}
        </h2>
        <p class:list={["mt-3 text-base text-gray-500", isLarge ? 'line-clamp-4' : 'line-clamp-3']}>
          {description}
        </p>
    </div>
    <div class="mt-6 flex items-center justify-between">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <img class="h-10 w-10 rounded-full object-cover" src={authorAvatar.src} alt={`Avatar of ${author}`} />
        </div>
        <div class="ml-3">
          <p class="text-base font-bold text-gray-900">{author}</p>
        </div>
      </div>
      <p class="text-sm text-gray-500">{new Date(publishDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
    </div>
  </div>
</a>