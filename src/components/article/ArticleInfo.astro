---
const { metadata } = Astro.props;
---
<div class="rounded-lg bg-white p-6 shadow-md">
    <h3 class="text-xl font-bold mb-4 border-b border-gray-200 pb-2">Info Artikel</h3>
    <ul class="space-y-4 text-sm">
        <li class="flex items-center justify-between">
            <div class="flex items-center text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-2 text-gray-400"><path fill-rule="evenodd" d="M5.75 2a.75.75 0 0 1 .75.75V4h7V2.75a.75.75 0 0 1 1.5 0V4h.25A2.75 2.75 0 0 1 18 6.75v8.5A2.75 2.75 0 0 1 15.25 18H4.75A2.75 2.75 0 0 1 2 15.25v-8.5A2.75 2.75 0 0 1 4.75 4H5V2.75A.75.75 0 0 1 5.75 2Zm-1 5.5h10.5a.75.75 0 0 0 0-1.5H4.75a.75.75 0 0 0 0 1.5Z" clip-rule="evenodd" /></svg>
                <span class="font-semibold">Terbit</span>
            </div>
            <span class="text-gray-800">{new Date(metadata.publishDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        </li>
        {metadata.lastUpdated && (
            <li class="flex items-center justify-between">
                <div class="flex items-center text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-2 text-gray-400"><path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.458 2.152l.209-.363a.75.75 0 0 0-1.3-.75l-.21.362a7 7 0 0 0 12.025-2.731.75.75 0 0 0-1.266-.67ZM4.688 8.576a5.5 5.5 0 0 1 9.458-2.152l-.209.363a.75.75 0 0 0 1.3.75l.21-.362a7 7 0 0 0-12.025 2.731.75.75 0 0 0 1.266.67Z" clip-rule="evenodd" /></svg>
                    <span class="font-semibold">Diperbarui</span>
                </div>
                <span class="text-gray-800">{new Date(metadata.lastUpdated).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </li>
        )}
        <li class="flex items-center justify-between">
            <div class="flex items-center text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-2 text-gray-400"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" /></svg>
                <span class="font-semibold">Waktu Baca</span>
            </div>
            <span class="text-gray-800">{metadata.readingTime} menit</span>
        </li>
    </ul>
</div>